{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",

    "rootDir": "src",
    "outDir": "dist",

    "lib": ["ES2022"],

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "removeComments": true,
    "sourceMap": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}